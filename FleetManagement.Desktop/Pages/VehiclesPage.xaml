<Page x:Class="FleetManagement.Desktop.Pages.VehiclesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Page.Resources>
        <!-- TEST: Bu style kesin uygulanmalı -->
        <Style x:Key="ForceComboBoxStyle" TargetType="ComboBox" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#122B57"/>
            <Setter Property="BorderBrush" Value="#243E70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FixDatePickerText" TargetType="{x:Type DatePicker}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FixCalendar" TargetType="{x:Type Calendar}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Black"/>
        </Style>

        <Style x:Key="ForceComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ARAÇ"
                               FontSize="22"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Araç kayıtlarını görüntüleyin ve yönetin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" MinWidth="120" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                        <TextBlock Text="Yenile"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" MinWidth="150" Click="New_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕" FontSize="16" Margin="0,0,6,0" Foreground="#9ACD32"/>
                        <TextBlock Text="Yeni Kayıt"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- ================= FORM ================= -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ARAÇ FORMU"
                               Foreground="Black"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                           Width="110" Click="Save_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0" Foreground="#32CD32"/>
                            <TextBlock Text="Kaydet"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Width="110" Click="Delete_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="16" Margin="0,0,6,0" Foreground="red"/>
                            <TextBlock Text="Sil"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Width="110" Click="Clear_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🧹" FontSize="16" Margin="0,0,6,0" Foreground="#00FFFF"/>
                            <TextBlock Text="Temizle"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- FORM CONTENT -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 1. Kolon -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="SÜRÜCÜ" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="AssignedDriverCombo"
                                              Margin="0,6,0,0"
                                              IsEditable="True"
                                              IsReadOnly="True"
                                              Foreground="Black"
                                              Background="#3D5869"
                                              BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>



                            <TextBlock Text="PLAKA"
                                       Foreground="{StaticResource BrushMuted}"
                                       Margin="0,6,0,0"/>
                            <TextBox x:Name="PlateBox"
                                     Margin="0,6,0,0"
                                     LostFocus="PlateBox_LostFocus"/>

                            <TextBlock Text="SİVİL PLAKA"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="InventoryNumberBox"
                                     Margin="0,6,0,0"/>



                            <TextBlock Text="AİT OLDUĞU TAKIM"
                                       Foreground="{StaticResource BrushMuted}"/>

                            <ComboBox x:Name="UnitCombo"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>


                        </StackPanel>

                        <!-- 2. Kolon -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ARAÇ CİNSİ"
                                       Foreground="{StaticResource BrushMuted}"
                                       Margin="0,6,0,0"/>
                            <ComboBox x:Name="VehicleTypeCombo"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>

                            <TextBlock Text="MARKA"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="BrandBox"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>

                            <TextBlock Text="MODEL"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="ModelCombo"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>

                            <TextBlock Text="ARAÇ YILI"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleYearBox"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>
                        </StackPanel>

                        <!-- 3. Kolon -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ARAÇ KM"
                                       Foreground="{StaticResource BrushMuted}"
                                       Margin="0,6,0,0"/>
                            <TextBox x:Name="VehicleKmBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="YOLCU KAPASİTESİ"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="PassengerCapacityBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="YÜK KAPASİTESİ"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="LoadCapacityBox"
                                     Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- 4. Kolon -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="MOTOR NO"
                                       Foreground="{StaticResource BrushMuted}"
                                       Margin="0,6,0,0"/>
                            <TextBox x:Name="MotorNoBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="ŞASE NO"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="SaseNoBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="ARAÇ DURUMU"
                                       Foreground="{StaticResource BrushMuted}"/>
                           
                            <ComboBox x:Name="VehicleSituationCombo"
                                         Margin="0,6,0,0"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         Foreground="Black"
                                         Background="#3D5869"
                                         BorderBrush="Black" SelectionChanged="VehicleSituationCombo_SelectionChanged">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>

                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="BAKIM DURUMU" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="MaintInfoBox"
                                       Margin="0,6,0,0"
                                       FontWeight="SemiBold"
                                       Text="—"/>
                        </StackPanel>

                        <!-- 5. Kolon -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="SON BAKIM KM"
                                       Foreground="{StaticResource BrushMuted}"
                                       Margin="0,6,0,0"/>
                            <TextBox x:Name="LastMaintenanceKmBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="SON BAKIM TARİHİ"
                                       Foreground="{StaticResource BrushMuted}"/>


                            <DatePicker x:Name="LastMaintenanceDatePicker"
                                        Margin="0,6,0,0"
                                        Style="{StaticResource FixDatePickerText}"
                                        CalendarStyle="{StaticResource FixCalendar}"/>


                            <TextBlock Text="BAKIM PERİYODU (KM)"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="MaintenanceIntervalKmBox"
                                     Margin="0,6,0,0"/>

                            <TextBlock Text="BAKIM PERİYODU (AY)"
                                       Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="MaintenanceIntervalMonthsBox"
                                     Margin="0,6,0,0"/>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= LIST ================= -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="ARAÇ LİSTESİ"
                           Foreground="{StaticResource BrushMuted}"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <DataGrid Grid.Row="2"
                          x:Name="VehiclesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="VehiclesGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <!-- 1. kolon -->
                        <DataGridTextColumn Header="PLAKA" Binding="{Binding Plate}" Width="60"/>
                        <DataGridTextColumn Header="SİVİL PLAKA" Binding="{Binding InventoryNumber}" Width="80"/>
                        <DataGridTextColumn Header="SÜRÜCÜ ADI" Binding="{Binding DriverFullName}" Width="120"/>
                        <DataGridTextColumn Header="AİT OLDUĞU TAKIM" Binding="{Binding VehicleUnit}" Width="100"/>

                        <!-- 2. kolon -->
                        <DataGridTextColumn Header="TİP" Binding="{Binding VehicleType}" Width="80"/>
                        <DataGridTextColumn Header="MARKA" Binding="{Binding Brand}" Width="80"/>
                        <DataGridTextColumn Header="MODEL" Binding="{Binding Model}" Width="90"/>
                        <DataGridTextColumn Header="YIL" Binding="{Binding VehicleYear}" Width="50"/>

                        <!-- 3. kolon -->
                        <DataGridTextColumn Header="KM" Binding="{Binding VehicleKm}" Width="50"/>
                        <DataGridTemplateColumn Header="ARAÇ DURUMU" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding VehicleSituation}"
                                               Foreground="{Binding VehicleSituationBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BAKIM DURUMU" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaintenanceStatus}"
                                               Foreground="{Binding MaintenanceBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 4. kolon -->

                        <DataGridTextColumn Header="YOLCU KAPASİTESİ" Binding="{Binding PassengerCapacity}" Width="60"/>
                        <DataGridTextColumn Header="YÜK KAPASİTESİ" Binding="{Binding LoadCapacity}" Width="60"/>
                        <DataGridTextColumn Header="MOTOR NO" Binding="{Binding MotorNo}" Width="60"/>
                        <DataGridTextColumn Header="ŞASE NO" Binding="{Binding SaseNo}" Width="60"/>


                        <!-- 5. kolon -->
                        <DataGridTextColumn Header="SON KM" Binding="{Binding LastMaintenanceKm}" Width="60"/>
                        <DataGridTextColumn Header="SON BAKIM TARİHİ"
                                            Binding="{Binding LastMaintenanceDate, StringFormat={}{0:yyyy-MM-dd}}"
                                            Width="60"/>
                        <DataGridTextColumn Header="BAKIM PERİYOT KM" Binding="{Binding MaintenanceIntervalKm}" Width="60"/>
                        <DataGridTextColumn Header="PERİYOT AY" Binding="{Binding MaintenanceIntervalMonths}" Width="60"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Page>