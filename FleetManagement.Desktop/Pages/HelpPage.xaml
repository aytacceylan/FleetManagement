<Page x:Class="FleetManagement.Desktop.Pages.HelpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="YARDIM"
                               FontSize="22"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Not / açıklama / kural ekleyebilir, kılavuzu açabilir veya dışa aktarabilirsiniz."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" MinWidth="140" Click="OpenGuide_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="📖" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                        <TextBlock Text="Kılavuzu Aç"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" MinWidth="150" Click="New_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕" FontSize="16" Margin="0,0,6,0" Foreground="#9ACD32"/>
                        <TextBlock Text="Yeni Kayıt"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="NOTLAR VE KURALLAR FORMU"
                               Foreground="Black"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                           Width="110" Click="Save_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0" Foreground="#32CD32"/>
                            <TextBlock Text="Kaydet"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Width="110" Click="Delete_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="16" Margin="0,0,6,0" Foreground="red"/>
                            <TextBlock Text="Sil"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Width="110" Click="Clear_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🧹" FontSize="16" Margin="0,0,6,0" Foreground="#00FFFF"/>
                            <TextBlock Text="Temizle"/>
                        </StackPanel>
                    </Button>
                    
                    
                </Grid>

                <!-- 2 kolon: Başlık + İçerik -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BAŞLIK" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="TitleBox" Margin="0,6,0,10"/>

                            <TextBlock Text="Kısa Not" Foreground="{StaticResource BrushMuted}"/>
                            <TextBlock Foreground="{StaticResource BrushMuted}" FontSize="12" Text="(İsteğe bağlı)"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AÇIKLAMA" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="ContentBox"
                                     Margin="0,6,0,10"
                                     Height="120"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- LIST -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="NOTLAR / KURALLAR"
                               FontSize="16"
                               Foreground="{StaticResource BrushMuted}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="FilterInfo"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="Grid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="Grid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NO" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="BAŞLIK" Binding="{Binding Title}" Width="220"/>
                        <DataGridTextColumn Header="AÇIKLAMA" Binding="{Binding Content}" Width="*"/>
                        <DataGridTextColumn Header="OLUŞTURMA" Binding="{Binding CreatedAt}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>