<Page x:Class="FleetManagement.Desktop.Pages.VehicleMovementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Page.Resources>
        <Style x:Key="ForceComboBoxStyle" TargetType="ComboBox" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#122B57"/>
            <Setter Property="BorderBrush" Value="#243E70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FixDatePickerText" TargetType="{x:Type DatePicker}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FixCalendar" TargetType="{x:Type Calendar}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Black"/>
        </Style>

        <Style x:Key="ForceComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Araç Hareket" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Araç hareket kayıtlarını oluşturun ve takip edin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" MinWidth="120" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                        <TextBlock Text="Yenile"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" MinWidth="150" Click="New_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕" FontSize="16" Margin="0,0,6,0" Foreground="#9ACD32"/>
                        <TextBlock Text="Yeni Kayıt"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- ================= FORM ================= -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Formu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                           Width="110" Click="Save_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0" Foreground="#32CD32"/>
                            <TextBlock Text="Kaydet"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Width="110" Click="Delete_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="16" Margin="0,0,6,0" Foreground="red"/>
                            <TextBlock Text="Sil"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Width="110" Click="Clear_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🧹" FontSize="16" Margin="0,0,6,0" Foreground="#00FFFF"/>
                            <TextBlock Text="Temizle"/>
                        </StackPanel>
                    </Button>
                    
                </Grid>

                <!-- FORM CONTENT -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 1. KOLON -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ÇIKIŞ NU." Foreground="{StaticResource BrushMuted}" Margin="0,0,0,0"/>
                            <TextBox x:Name="DailyNoBox" Margin="0,6,0,0" IsReadOnly="True"/>

                            <TextBlock Text="SÜRÜCÜ RÜTBESİ ADI SOYADI" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DriverCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="PLAKA" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <TextBlock Text="ARAÇ CİNSİ" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleTypeCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <!-- 2. KOLON -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ÇIKIŞ TARİHİ" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ExitDatePicker"
                                        Margin="0,5,0,0"
                                        Style="{StaticResource FixDatePickerText}"
                                        CalendarStyle="{StaticResource FixCalendar}"/>

                            <TextBlock Text="ÇIKIŞ SAATİ" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="ExitTimeBox" Margin="0,6,0,10" Text="08:00"/>

                            <TextBlock Text="DÖNÜŞ TARİHİ" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ReturnDatePicker"
                                        Margin="0,6,0,0"
                                        Style="{StaticResource FixDatePickerText}"
                                        CalendarStyle="{StaticResource FixCalendar}"/>

                            <TextBlock Text="DÖNÜŞ SAATİ" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ReturnTimeBox" Margin="0,6,0,0" />


                        </StackPanel>

                        <!-- 3. KOLON -->
                        <StackPanel Grid.Column="4">
                            
                            
                            
                            <TextBlock Text="GÖREV DURUMU" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="StatusBox" Margin="0,6,0,10" IsReadOnly="True"/>


                            <TextBlock Text="GİDİLECEK YER" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="RouteCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <!-- 4. KOLON -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="ARAÇ KOMUTANI" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <ComboBox x:Name="CommanderCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="EMRİNE GİRDİĞİ BRL./KS." Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DepartureCombo"
                                      Margin="0,6,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                           
                        </StackPanel>

                        <!-- 5. KOLON -->
                        <StackPanel Grid.Column="8">

                            <TextBlock Text="YAPILAN KM." Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="DoneKmBox" Margin="0,5,0,0"/>
                            
                            <TextBlock Text="YOLCU SAYISI" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="PassengerCountBox" Margin="0,5,0,0"/>

                            <TextBlock Text="YÜK MİKTARI" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="LoadAmountBox" Margin="0,5,0,0"/>

                            <TextBlock Text="ÇIKIŞ TÜRÜ" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DutyTypeCombo"
                                      Margin="0,5,0,0"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= LIST ================= -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ARAÇ HAREKET LİSTESİ"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Width="120" Click="ExportDaily_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                            <TextBlock Text="Günlük Aktar"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Width="120" Click="ExportMonthly_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                            <TextBlock Text="Aylık Aktar"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="5">
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="FilterInfo"
                   Margin="0,6,0,0"
                   Foreground="{StaticResource BrushMuted}"
                   FontSize="12"
                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="MovementsGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          
                          SelectionChanged="MovementsGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SEVK NO" Binding="{Binding MovementNo}" Width="100"/>
                        <DataGridTextColumn Header="ÇIKIŞ NU." Binding="{Binding DailyNo}" Width="70"/>
                        <DataGridTextColumn Header="PLAKA" Binding="{Binding Plate}" Width="80"/>
                        <DataGridTextColumn Header="SÜRÜCÜ RÜTBESİ ADI SOYADI" Binding="{Binding Driver}" Width="140"/>
                        <DataGridTextColumn Header=" ARAÇ CİNSİ" Binding="{Binding VehicleType}" Width="90"/>
                        <DataGridTextColumn Header="ARAÇ KOMUTANI" Binding="{Binding Commander}" Width="120"/>
                        <DataGridTextColumn Header="EMRİNE GİRDİĞİ BRL./KS." Binding="{Binding Departure}" Width="150"/>
                        <DataGridTextColumn Header="YOLCU SAYISI" Binding="{Binding PassengerCount}" Width="110"/>
                        <DataGridTextColumn Header="YÜK MİKTARI" Binding="{Binding LoadAmount}" Width="100"/>
                        <DataGridTextColumn Header="GİDİLECEK YER" Binding="{Binding Route}" Width="100"/>
                        <DataGridTextColumn Header="TARİH" Binding="{Binding DateText}" Width="80"/>
                        <DataGridTextColumn Header="ÇIKIŞ SAATİ" Binding="{Binding ExitTimeText}" Width="90"/>
                        <DataGridTextColumn Header="DÖNÜŞ SAATİ" Binding="{Binding ReturnTimeText}" Width="100"/>
                        <DataGridTextColumn Header="YAPILAN KM" Binding="{Binding KmText}" Width="90"/>
                        <DataGridTextColumn Header="ÇIKIŞ TÜRÜ" Binding="{Binding DutyType}" Width="100"/>
                        <DataGridTemplateColumn Header="DURUM" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>



                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>