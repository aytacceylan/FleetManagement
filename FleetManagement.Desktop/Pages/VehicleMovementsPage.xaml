<Page x:Class="FleetManagement.Desktop.Pages.VehicleMovementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Page.Resources>
        <Style x:Key="ForceComboBoxStyle" TargetType="ComboBox" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#122B57"/>
            <Setter Property="BorderBrush" Value="#243E70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FixDatePickerText" TargetType="{x:Type DatePicker}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FixCalendar" TargetType="{x:Type Calendar}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Black"/>
        </Style>

        <Style x:Key="ForceComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Araç Hareket" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Araç hareket kayıtlarını oluşturun ve takip edin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Yenile" MinWidth="120" Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="Yeni Kayıt" MinWidth="150" Click="New_Click"/>
            </Grid>
        </Border>

        <!-- ================= FORM ================= -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Formu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Kaydet" Width="110" Click="Save_Click"/>
                    <Button Grid.Column="3" Content="Sil" Width="110" Click="Delete_Click"/>
                    <Button Grid.Column="5" Content="Temizle" Width="110" Click="Clear_Click"/>
                </Grid>

                <!-- FORM CONTENT -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 1. KOLON -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sıra No" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="DailyNoBox" Margin="0,6,0,10" IsReadOnly="True"/>

                            <TextBlock Text="Sürücü" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DriverCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="Plaka" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <!-- 2. KOLON -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Çıkış Saati" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="ExitTimeBox" Margin="0,6,0,10" Text="08:00"/>

                            <TextBlock Text="Dönüş Tarihi" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ReturnDatePicker"
                                        Margin="0,6,0,10"
                                        Style="{StaticResource FixDatePickerText}"
                                        CalendarStyle="{StaticResource FixCalendar}"/>

                            <TextBlock Text="Dönüş Saati" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ReturnTimeBox" Margin="0,6,0,10" Text="17:00"/>

                            <TextBlock Text="Araç Marka" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleBrandCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <!-- 3. KOLON -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Görev Durumu" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="StatusBox" Margin="0,6,0,10" IsReadOnly="True"/>

                            <TextBlock Text="Tarih" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ExitDatePicker"
                                        Margin="0,6,0,10"
                                        Style="{StaticResource FixDatePickerText}"
                                        CalendarStyle="{StaticResource FixCalendar}"/>

                            <TextBlock Text="Güzergah" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="RouteCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <!-- 4. KOLON -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Araç Komutanı" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <ComboBox x:Name="CommanderCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="Başkanlık" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DepartureCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="Yapılan Km." Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="DoneKmBox" Margin="0,6,0,10"/>
                        </StackPanel>

                        <!-- 5. KOLON -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="Taşınan Yolcu" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="PassengerCountBox" Margin="0,6,0,10"/>

                            <TextBlock Text="Taşınan Yük" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="LoadAmountBox" Margin="0,6,0,10"/>

                            <TextBlock Text="Görev Türü" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DutyTypeCombo"
                                      Margin="0,6,0,10"
                                      IsEditable="True"
                                      IsReadOnly="True"
                                      Foreground="Black"
                                      Background="#3D5869"
                                      BorderBrush="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= LIST ================= -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Listesi"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="FilterInfo"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="MovementsGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="MovementsGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sıra No" Binding="{Binding DailyNo}" Width="70"/>
                        <DataGridTextColumn Header="Sürücü" Binding="{Binding Driver}" Width="160"/>
                        <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="110"/>
                        <DataGridTextColumn Header="Çıkış Saati" Binding="{Binding ExitTimeText}" Width="90"/>
                        <DataGridTextColumn Header="Dönüş Saati" Binding="{Binding ReturnTimeText}" Width="90"/>
                        <DataGridTextColumn Header="Araç Marka" Binding="{Binding VehicleBrand}" Width="120"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding DateText}" Width="95"/>
                        <DataGridTextColumn Header="Güzergah" Binding="{Binding Route}" Width="140"/>
                        <DataGridTextColumn Header="Araç Komutanı" Binding="{Binding Commander}" Width="160"/>
                        <DataGridTextColumn Header="Başkanlık" Binding="{Binding Departure}" Width="140"/>
                        <DataGridTextColumn Header="Yapılan Km" Binding="{Binding KmText}" Width="90"/>
                        <DataGridTextColumn Header="Taşınan Yolcu" Binding="{Binding PassengerCount}" Width="110"/>
                        <DataGridTextColumn Header="Taşınan Yük" Binding="{Binding LoadAmount}" Width="110"/>
                        <DataGridTextColumn Header="Görev Türü" Binding="{Binding DutyType}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>