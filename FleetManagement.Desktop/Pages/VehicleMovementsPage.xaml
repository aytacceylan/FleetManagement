<Page x:Class="FleetManagement.Desktop.Pages.VehicleMovementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Page.Resources>
        <!-- TEST: Bu style kesin uygulanmalı -->
        <Style x:Key="ForceComboBoxStyle" TargetType="ComboBox" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#122B57"/>
            <Setter Property="BorderBrush" Value="#243E70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FixDatePickerText" TargetType="{x:Type DatePicker}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FixCalendar" TargetType="{x:Type Calendar}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Black"/>
        </Style>

        <Style x:Key="ForceComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{x:Null}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#122B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="260"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Araç Hareket" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Araç hareket kayıtlarını oluşturun ve takip edin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Yenile" MinWidth="120" Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="Yeni Kayıt" MinWidth="150" Click="New_Click"/>
            </Grid>
        </Border>

        <!-- ================= FORM ================= -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Formu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Kaydet" Width="110" Click="Save_Click"/>
                    <Button Grid.Column="3" Content="Sil" Width="110" Click="Delete_Click"/>
                    <Button Grid.Column="5" Content="Temizle" Width="110" Click="Clear_Click"/>
                </Grid>

                <!-- FORM CONTENT: 5 kolon, eşit dağılım, sol üstten sağ alta -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ROW 0 -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Araç (Plaka)" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="VehicleCombo"
             Margin="0,6,0,10"
             IsEditable="True"
             IsReadOnly="True"
             Foreground="Black"
             Background="#3D5869"
             BorderBrush="Black">

                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <!-- Normal liste -->
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="black"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>

                                            <!-- Seçili -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Black"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Sürücü" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="DriverCombo" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="4">
                            <TextBlock Text="Araç Komutanı" Foreground="{StaticResource BrushMuted}"/>
                            <ComboBox x:Name="CommanderCombo" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="6">
                            <TextBlock Text="Çıkış Tarih" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ExitDatePicker" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="8">
                            <TextBlock Text="Çıkış Saat (HH:mm)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ExitTimeBox" Margin="0,6,0,8" Text="08:00"/>
                        </StackPanel>

                        <!-- ROW 1 -->
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Plaka (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="VehiclePlateTextBox" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="Sürücü (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="DriverTextBox" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="4">
                            <TextBlock Text="Komutan (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="CommanderTextBox" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="6">
                            <TextBlock Text="Dönüş Tarih" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ReturnDatePicker" Margin="0,6,0,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="8">
                            <TextBlock Text="Dönüş Saat (HH:mm)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ReturnTimeBox" Margin="0,6,0,8" Text="17:00"/>
                        </StackPanel>

                        <!-- ROW 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Güzergah (Rota)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="RouteBox" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Başkanlık / Amaç" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="PurposeBox" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="4">
                            <TextBlock Text="Taşınan (Yolcu/Yük)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="LoadOrPassengerBox" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="6">
                            <TextBlock Text="Başlangıç KM" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="StartKmBox" Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="8">
                            <TextBlock Text="Bitiş KM" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="EndKmBox" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= LIST ================= -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Listesi"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="FilterInfo"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="MovementsGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="MovementsGrid_SelectionChanged">

                    <!-- Kolon sırası: senin istediğin sıraya göre -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sıra No" Binding="{Binding DailyNo}" Width="70"/>
                        <DataGridTextColumn Header="Sürücü" Binding="{Binding Driver}" Width="160"/>
                        <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="110"/>
                        <DataGridTextColumn Header="Çıkış Saati" Binding="{Binding ExitTimeText}" Width="90"/>
                        <DataGridTextColumn Header="Dönüş Saati" Binding="{Binding ReturnTimeText}" Width="90"/>
                        <DataGridTextColumn Header="Araç Marka" Binding="{Binding VehicleBrand}" Width="120"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding DateText}" Width="95"/>
                        <DataGridTextColumn Header="Güzergah" Binding="{Binding Route}" Width="140"/>
                        <DataGridTextColumn Header="Araç Komutanı" Binding="{Binding Commander}" Width="160"/>

                        <!-- Şimdilik Purpose alanını Başkanlık gibi kullanıyoruz -->
                        <DataGridTextColumn Header="Başkanlık" Binding="{Binding Purpose}" Width="140"/>

                        <!-- Yapılan Km: şimdilik DoneKm/KmText -->
                        <DataGridTextColumn Header="Yapılan Km" Binding="{Binding KmText}" Width="90"/>

                        <!-- Yolcu/Yük: şimdilik tek alan -->
                        <DataGridTextColumn Header="Taşınan (Y/Y)" Binding="{Binding LoadOrPassengerInfo}" Width="150"/>

                        <!-- Görev Türü: şimdilik Description alanı -->
                        <DataGridTextColumn Header="Görev Türü" Binding="{Binding Description}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Page>