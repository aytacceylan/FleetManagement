<Page x:Class="FleetManagement.Desktop.Pages.VehicleMovementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="320"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Araç Hareket" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Araç hareket kayıtlarını oluşturun ve takip edin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Yenile" MinWidth="120" Click="Refresh_Click"/>
                <Button Grid.Column="3" Content="Yeni Kayıt" MinWidth="150" Click="New_Click"/>
            </Grid>
        </Border>

        <!-- ================= FORM ================= -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Formu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Kaydet" Width="110" Click="Save_Click"/>
                    <Button Grid.Column="3" Content="Sil" Width="110" Click="Delete_Click"/>
                    <Button Grid.Column="5" Content="Temizle" Width="110" Click="Clear_Click"/>
                </Grid>

                <!-- FORM CONTENT (5 kolon) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 1) Araç -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Araç" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <ComboBox x:Name="VehicleCombo" Margin="0,6,0,10"/>

                            <TextBlock Text="Araç (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="VehiclePlateTextBox" Margin="0,6,0,10"/>
                        </StackPanel>

                        <!-- 2) Sürücü -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Sürücü" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <ComboBox x:Name="DriverCombo" Margin="0,6,0,10"/>

                            <TextBlock Text="Sürücü (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="DriverTextBox" Margin="0,6,0,10"/>
                        </StackPanel>

                        <!-- 3) Komutan -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Araç Komutanı" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <ComboBox x:Name="CommanderCombo" Margin="0,6,0,10"/>

                            <TextBlock Text="Komutan (Serbest)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="CommanderTextBox" Margin="0,6,0,10"/>
                        </StackPanel>

                        <!-- 4) Tarih/Saat -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Çıkış Tarih" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <DatePicker x:Name="ExitDatePicker" Margin="0,6,0,10"/>

                            <TextBlock Text="Çıkış Saat (HH:mm)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ExitTimeBox" Margin="0,6,0,10" Text="08:00"/>

                            <TextBlock Text="Dönüş Tarih" Foreground="{StaticResource BrushMuted}"/>
                            <DatePicker x:Name="ReturnDatePicker" Margin="0,6,0,10"/>

                            <TextBlock Text="Dönüş Saat (HH:mm)" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="ReturnTimeBox" Margin="0,6,0,10" Text="17:00"/>
                        </StackPanel>

                        <!-- 5) Görev/Km -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="Rota" Foreground="{StaticResource BrushMuted}" Margin="0,8,0,0"/>
                            <TextBox x:Name="RouteBox" Margin="0,6,0,10"/>

                            <TextBlock Text="Amaç" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="PurposeBox" Margin="0,6,0,10"/>

                            <TextBlock Text="Yük / Yolcu" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="LoadOrPassengerBox" Margin="0,6,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Başlangıç KM" Foreground="{StaticResource BrushMuted}"/>
                                    <TextBox x:Name="StartKmBox" Margin="0,6,0,10"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bitiş KM" Foreground="{StaticResource BrushMuted}"/>
                                    <TextBox x:Name="EndKmBox" Margin="0,6,0,10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Açıklama" Foreground="{StaticResource BrushMuted}"/>
                            <TextBox x:Name="DescBox" Margin="0,6,0,0"/>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= LIST ================= -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Hareket Listesi"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="FilterInfo"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="MovementsGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="MovementsGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Araç" Binding="{Binding VehicleDisplay}" Width="140"/>
                        <DataGridTextColumn Header="Sürücü" Binding="{Binding DriverDisplay}" Width="160"/>
                        <DataGridTextColumn Header="Komutan" Binding="{Binding CommanderDisplay}" Width="160"/>
                        <DataGridTextColumn Header="Çıkış" Binding="{Binding ExitDateTimeText}" Width="160"/>
                        <DataGridTextColumn Header="Dönüş" Binding="{Binding ReturnDateTimeText}" Width="160"/>
                        <DataGridTextColumn Header="Rota" Binding="{Binding Route}" Width="140"/>
                        <DataGridTextColumn Header="Amaç" Binding="{Binding Purpose}" Width="140"/>
                        <DataGridTextColumn Header="KM" Binding="{Binding KmText}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Page>