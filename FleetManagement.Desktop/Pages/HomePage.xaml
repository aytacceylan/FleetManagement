<Page x:Class="FleetManagement.Desktop.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <StackPanel>
                <TextBlock Text="Ana Sayfa"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Genel durum özeti ve canlı operasyon ekranı"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource BrushMuted}"/>
            </StackPanel>
        </Border>

        <!-- TOP CARDS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1 -->
            <Border Grid.Column="0" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="Sürücü Durumu"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="Black"/>
                    <TextBlock x:Name="DriverSummaryText"
                   Margin="0,10,0,0"
                   Foreground="Black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Görevde: 0 | Müsait: 0"/>
                </StackPanel>
            </Border>

            <!-- 2 -->
            <Border Grid.Column="2" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="Araç Durumu"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="VehicleSummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Devam: 0 | Planlı: 0 | Müsait: 0"/>
                </StackPanel>
            </Border>

            <!-- 3 -->
            <Border Grid.Column="4" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="Bakım Özeti"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="MaintenanceSummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Geciken: 0 | Yaklaşan: 0 | Normal: 0"/>
                </StackPanel>
            </Border>

            <!-- 4 -->
            <Border Grid.Column="6" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="Bugünkü Hareketler"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="TodaySummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Tamamlanan: 0 | Devam: 0 | Planlı: 0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- LOWER SECTION -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1: Müsait Araçlar -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Müsait Araçlar"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="AvailableVehiclesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="Araç Marka" Binding="{Binding VehicleBrand}" Width="120"/>
                            <DataGridTextColumn Header="Takım" Binding="{Binding VehicleUnit}" Width="130"/>
                            <DataGridTextColumn Header="Km" Binding="{Binding VehicleKm}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 2: Müsait Sürücüler -->
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Müsait Sürücüler"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="AvailableDriversGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sürücü" Binding="{Binding FullName}" Width="180"/>
                            <DataGridTextColumn Header="Numara" Binding="{Binding DriverNumber}" Width="110"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding PhoneNumber}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 3: Bakımı Geçen / Yaklaşan -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Bakımı Geçen / Yaklaşan Araçlar"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="MaintenanceGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="Araç Marka" Binding="{Binding VehicleBrand}" Width="120"/>
                            <DataGridTextColumn Header="Mevcut Km" Binding="{Binding CurrentKm}" Width="90"/>
                            <DataGridTextColumn Header="Son Bakım Km" Binding="{Binding LastMaintenanceKm}" Width="100"/>
                            <DataGridTextColumn Header="Son Bakım Tarihi" Binding="{Binding LastMaintenanceDateText}" Width="110"/>
                            <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 4: Görevi Devam Eden Hareketler -->
            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Görevi Devam Eden Hareketler"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="OngoingMovementsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Plaka" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="Sürücü" Binding="{Binding Driver}" Width="150"/>
                            <DataGridTextColumn Header="Çıkış" Binding="{Binding ExitTime}" Width="90"/>
                            <DataGridTextColumn Header="Güzergah" Binding="{Binding Route}" Width="140"/>
                            <DataGridTextColumn Header="Araç Marka" Binding="{Binding VehicleBrand}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>