<Page x:Class="FleetManagement.Desktop.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Başlık -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Ana Sayfa"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                        <TextBlock Text="Genel durum özeti ve canlı operasyon ekranı"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource BrushMuted}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                       x:Name="LastUpdateText"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BrushMuted}"
                       FontSize="12"
                       Text="Son Güncelleme: --:--"/>
                </Grid>

                <!-- Butonlar -->
                <WrapPanel Grid.Row="2" ItemHeight="38" Orientation="Horizontal">
                    <Button MinWidth="135" Margin="0,0,8,8" Padding="14,6" Click="Form110_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,6,0" Foreground="Brown"/>
                            <TextBlock Text="FORM 110"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="160" Margin="0,0,8,8" Padding="14,6" Click="PromissoryNote_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,6,0" Foreground="#2E8B57"/>
                            <TextBlock Text="EL SENEDİ ÖRNEĞİ"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="165" Margin="0,0,8,8" Padding="14,6" Click="DriverInstruction_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📖" FontSize="16" Margin="0,0,6,0" Foreground="#8B4513"/>
                            <TextBlock Text="SÜRÜCÜ TALİMATI"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="200" Margin="0,0,8,8" Padding="14,6" Click="CommanderInstruction_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📖" FontSize="16" Margin="0,0,6,0" Foreground="#8B4513"/>
                            <TextBlock Text="ARAÇ KOMUTANI TALİMATI"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="220" Margin="0,0,8,8" Padding="14,6" Click="GarageInstruction_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📖" FontSize="16" Margin="0,0,6,0" Foreground="#8B4513"/>
                            <TextBlock Text="KATLI GARAJ DEVAMLI TALİMATI"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="230" Margin="0,0,8,8" Padding="14,6" Click="AfterHoursRequestForm_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,6,0" Foreground="#A0522D"/>
                            <TextBlock Text="MESAİ DIŞINDA ARAÇ TALEP FORMU"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="130" Margin="0,0,8,8" Padding="14,6" Click="VehicleList_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🚗" FontSize="16" Margin="0,0,6,0" Foreground="Red"/>
                            <TextBlock Text="Araç Listesi"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="130" Margin="0,0,8,8" Padding="14,6" Click="DriverList_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="👤" FontSize="16" Margin="0,0,6,0" Foreground="Purple"/>
                            <TextBlock Text="Sürücü Listesi"/>
                        </StackPanel>
                    </Button>

                    <Button MinWidth="130" Margin="0,0,8,8" Padding="14,6" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔄" FontSize="16" Margin="0,0,6,0" Foreground="#CCCC00"/>
                            <TextBlock Text="Yenile"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- TOP CARDS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1 -->
            <Border Grid.Column="0" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="SÜRÜCÜ DURUMU"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="Black"/>
                    <TextBlock x:Name="DriverSummaryText"
                   Margin="0,10,0,0"
                   Foreground="Black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Müsait: 0 | Sürüş: 0 | İzin: 0 | Görevl.: 0 | YDGG: 0 | İstirahat: 0 | Birlik İçi: 0 | Diğer: 0"/>
                </StackPanel>
            </Border>

            <!-- 2 -->
            <Border Grid.Column="2" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="ARAÇ DURUMU"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="VehicleSummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Müsait: 0 | Görevde: 0 | Kademe: 0 | Servis: 0 | Fabrika: 0"/>
                </StackPanel>
            </Border>

            <!-- 3 -->
            <Border Grid.Column="4" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="BAKIM ÖZETİ"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="MaintenanceSummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Geciken: 0 | Yaklaşan: 0 | Normal: 0"/>
                </StackPanel>
            </Border>

            <!-- 4 -->
            <Border Grid.Column="6" Style="{StaticResource FmCard}" MinHeight="95">
                <StackPanel>
                    <TextBlock Text="BUGÜNKÜ HAREKETLER"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="black"/>
                    <TextBlock x:Name="TodaySummaryText"
                   Margin="0,10,0,0"
                   Foreground="black"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="Toplam: 0 | Tamamlanan: 0 | Devam: 0 | Planlı: 0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- LOWER SECTION -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1: Müsait Araçlar -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="MÜSAİT ARAÇLAR"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="AvailableVehiclesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PLAKA" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="ARAÇ MARKA" Binding="{Binding VehicleBrand}" Width="120"/>
                            <DataGridTextColumn Header="AİT OLDUĞU TAKIM" Binding="{Binding VehicleUnit}" Width="130"/>
                            <DataGridTextColumn Header="KM" Binding="{Binding VehicleKm}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 2: Müsait Sürücüler -->
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="MÜSAİT SÜRÜCÜLER"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="AvailableDriversGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SÜRÜCÜ" Binding="{Binding FullName}" Width="180"/>
                            <DataGridTextColumn Header="SÜRÜCÜ NUMARA" Binding="{Binding DriverNumber}" Width="110"/>
                            <DataGridTextColumn Header="TELEFON" Binding="{Binding PhoneNumber}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 3: Görevi Devam Eden Hareketler -->
            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="GÖREVİ DEVAM EDEN HAREKETLER"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="OngoingMovementsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PLAKA" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="SÜRÜCÜ" Binding="{Binding Driver}" Width="150"/>
                            <DataGridTextColumn Header="ÇIKIŞ" Binding="{Binding ExitTime}" Width="90"/>
                            <DataGridTextColumn Header="GİDİLEN YER" Binding="{Binding Route}" Width="140"/>
                            <DataGridTextColumn Header="ARAÇ MARKA" Binding="{Binding VehicleBrand}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 4: Bakımı Geçen / Yaklaşan -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FmCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="BAKIMI GEÇEN / YAKLAŞAN ARAÇLAR"
                       Foreground="Black"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                      x:Name="MaintenanceGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PLAKA" Binding="{Binding Plate}" Width="100"/>
                            <DataGridTextColumn Header="ARAÇ MARKA" Binding="{Binding VehicleBrand}" Width="120"/>
                            <DataGridTextColumn Header="MEVCUT KM" Binding="{Binding CurrentKm}" Width="90"/>
                            <DataGridTextColumn Header="SON BAKIM KM" Binding="{Binding LastMaintenanceKm}" Width="100"/>
                            <DataGridTextColumn Header="SON BAKIM TARİHİ" Binding="{Binding LastMaintenanceDateText}" Width="110"/>
                            <DataGridTextColumn Header="DURUM" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>


            
        </Grid>
    </Grid>
</Page>