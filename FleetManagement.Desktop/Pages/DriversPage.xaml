<Page x:Class="FleetManagement.Desktop.Pages.DriversPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Sürücüler"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Sürücü tanımlarını yönetin."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"/>
                </StackPanel>

                <Button Grid.Column="1" MinWidth="120" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="16" Margin="0,0,6,0" Foreground="#FFFF00"/>
                        <TextBlock Text="Yenile"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" MinWidth="150" Click="New_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕" FontSize="16" Margin="0,0,6,0" Foreground="#9ACD32"/>
                        <TextBlock Text="Yeni Kayıt"/>
                    </StackPanel>
                </Button>


            </Grid>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="2" Style="{StaticResource FmCard}">
            <Grid Margin="4">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Sürücü Formu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                           Width="110" Click="Save_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0" Foreground="#32CD32"/>
                            <TextBlock Text="Kaydet"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Width="110" Click="Delete_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="16" Margin="0,0,6,0" Foreground="red"/>
                            <TextBlock Text="Sil"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Width="110" Click="Clear_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🧹" FontSize="16" Margin="0,0,6,0" Foreground="#00FFFF"/>
                            <TextBlock Text="Temizle"/>
                        </StackPanel>
                    </Button>
                    
                </Grid>

                <!-- 3 PROPERTY = 3 KOLON -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sürücü No -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sürücü No"
                                   Foreground="{StaticResource BrushMuted}"/>
                        <TextBox x:Name="DriverNumberBox"
                                 Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Ad Soyad -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ad Soyad"
                                   Foreground="{StaticResource BrushMuted}"/>
                        <TextBox x:Name="FullNameBox"
                                 Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Telefon -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Telefon"
                                   Foreground="{StaticResource BrushMuted}"/>
                        <TextBox x:Name="PhoneBox"
                                 Margin="0,6,0,0"/>
                    </StackPanel>

                </Grid>

            </Grid>
        </Border>

        <!-- LIST -->
        <Border Grid.Row="4" Style="{StaticResource FmCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Sürücü Listesi"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="SearchBox"
                                 TextChanged="SearchBox_TextChanged"/>

                        <TextBlock x:Name="FilterInfo"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   Text="Toplam kayıt: 0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="DriversGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="DriversGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sürücü No" Binding="{Binding DriverNumber}" Width="140"/>
                        <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding PhoneNumber}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </Grid>
</Page>